# انسخ هذا الملفَّ إلى .cloudflare.env (مُتجاهَلٌ في git) وضع توكنك:
# أنشئ التوكن من: dash.cloudflare.com → My Profile → API Tokens → Create Token
# الصلاحيّات المطلوبة: Account · Workers Scripts:Edit · D1:Edit · Account Settings:Read
CLOUDFLARE_API_TOKEN=
# (اختياريّ إن تعدّدت الحسابات) CLOUDFLARE_ACCOUNT_ID=
