{
  "name": "influential-masjid-platform",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "preview": "wrangler pages dev .output/public --d1 DB --compatibility-flags nodejs_compat",
    "deploy": "nuxt build && wrangler pages deploy .output/public",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply influential-masjid --local",
    "db:migrate:remote": "wrangler d1 migrations apply influential-masjid --remote",
    "db:seed:local": "wrangler d1 execute influential-masjid --local --file=./server/database/seed.sql",
    "db:seed:points:local": "wrangler d1 execute influential-masjid --local --file=./server/database/seed_points.sql",
    "typecheck": "nuxt typecheck",
    "test": "vitest run"
  },
  "dependencies": {
    "@cloudflare/puppeteer": "^0.0.14",
    "drizzle-orm": "^0.36.0",
    "jose": "^5.9.0",
    "nuxt": "^3.13.0",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@nuxtjs/tailwindcss": "^6.12.0",
    "@vite-pwa/nuxt": "^0.10.0",
    "better-sqlite3": "^11.0.0",
    "drizzle-kit": "^0.28.0",
    "vitest": "^2.1.0",
    "wrangler": "^3.80.0"
  }
}
